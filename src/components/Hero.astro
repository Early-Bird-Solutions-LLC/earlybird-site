---
// Hero.astro — Home page hero with editorial layout.
// Content is hardcoded here intentionally; the hero is visual identity, not editable content.
---

<section class="hero">
  <div class="container">
    <div class="hero-grid">
      <div>
        <div class="hero-eyebrow rise">
          <span class="line"></span>
          <span class="mono-label">Azure AI Consulting · Est. 2026</span>
        </div>
        <h1 class="hero-headline rise">
          AI that <em>ships</em>, on the Microsoft stack you already run.
        </h1>
        <p class="hero-sub rise">
          Independent consulting from a Microsoft Certified Solutions Architect.
          I help enterprises ship AI on Azure — including the regulated, complex,
          and .NET-heavy environments others avoid.
        </p>
        <div class="hero-cta-row rise">
          <a href="/contact" class="btn-primary">
            Schedule a call
            <span class="arrow">→</span>
          </a>
          <a href="/work" class="btn-secondary">See selected work</a>
        </div>
      </div>

      <div class="hero-meta">
        <div class="hero-meta-block rise">
          <div class="hero-meta-label">Practitioner</div>
          <div class="hero-meta-value">Jim Keeley</div>
          <div class="hero-meta-value small">
            Senior Platform Engineer · Florida, USA
          </div>
        </div>
        <div class="hero-meta-block rise">
          <div class="hero-meta-label">Certifications</div>
          <div class="hero-meta-value small">
            Microsoft Certified — Azure Solutions Architect Expert
          </div>
          <div class="hero-meta-value small">
            Microsoft Certified — Azure Administrator Associate
          </div>
        </div>
        <div class="hero-meta-block rise">
          <div class="hero-meta-label">Currently</div>
          <div class="hero-meta-value small">
            Platform engineer on a PCI-DSS multi-tenant fintech platform
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 120px 0 100px;
    position: relative;
    overflow: hidden;
  }

  /* Dot grid background */
  .hero::before {
    content: '';
    position: absolute;
    top: 0;
    right: -50px;
    width: 60%;
    height: 100%;
    background-image: radial-gradient(circle, var(--rule) 1px, transparent 1px);
    background-size: 24px 24px;
    opacity: 0.5;
    mask-image: radial-gradient(ellipse at top right, black 30%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse at top right, black 30%, transparent 70%);
    pointer-events: none;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: end;
    position: relative;
    z-index: 2;
  }

  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 40px;
    animation-delay: 0.05s;
  }

  .hero-eyebrow .line {
    width: 36px;
    height: 1px;
    background: var(--accent);
  }

  .hero-headline {
    font-family: var(--serif);
    font-size: clamp(48px, 7vw, 92px);
    line-height: 1.02;
    letter-spacing: -0.02em;
    font-weight: 400;
    margin-bottom: 32px;
    animation-delay: 0.15s;
  }

  .hero-headline em {
    font-style: italic;
    color: var(--accent-deep);
  }

  .hero-sub {
    font-size: 18px;
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 460px;
    margin-bottom: 40px;
    animation-delay: 0.3s;
  }

  .hero-cta-row {
    display: flex;
    gap: 24px;
    align-items: center;
    animation-delay: 0.4s;
  }

  .hero-meta {
    border-left: 1px solid var(--rule);
    padding-left: 40px;
    padding-bottom: 20px;
  }

  .hero-meta-block {
    margin-bottom: 32px;
  }
  .hero-meta-block:last-child {
    margin-bottom: 0;
  }
  .hero-meta-block:nth-child(1) {
    animation-delay: 0.5s;
  }
  .hero-meta-block:nth-child(2) {
    animation-delay: 0.6s;
  }
  .hero-meta-block:nth-child(3) {
    animation-delay: 0.7s;
  }

  .hero-meta-label {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: 8px;
  }

  .hero-meta-value {
    font-family: var(--serif);
    font-size: 22px;
    line-height: 1.35;
    color: var(--ink);
  }

  .hero-meta-value.small {
    font-family: var(--sans);
    font-size: 15px;
    color: var(--ink-soft);
  }

  @media (max-width: 900px) {
    .hero {
      padding: 60px 0 80px;
    }
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .hero-meta {
      border-left: none;
      border-top: 1px solid var(--rule);
      padding-left: 0;
      padding-top: 32px;
    }
  }
</style>
