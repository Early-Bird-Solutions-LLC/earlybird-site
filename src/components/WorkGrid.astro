---
import type { AstroComponentFactory } from 'astro/runtime/server/index.js';
import { getCollection } from 'astro:content';
import HrAssistant from './case-thumbs/HrAssistant.astro';
import ConfluenceRag from './case-thumbs/ConfluenceRag.astro';
import TechnicalManuals from './case-thumbs/TechnicalManuals.astro';
import NetModernization from './case-thumbs/NetModernization.astro';

const work = (await getCollection('work')).sort(
  (a, b) => a.data.order - b.data.order,
);

// Map slug → thumbnail component
const thumbs: Record<string, AstroComponentFactory> = {
  'hr-assistant': HrAssistant,
  'conflux-rag': ConfluenceRag,
  'technical-manuals-rag': TechnicalManuals,
  'net-modernization': NetModernization,
};
---

<section id="work" class="section work">
  <div class="container">
    <div class="section-head">
      <div class="section-num">§ 02 — Selected work</div>
      <h2 class="section-title">
        A small selection of recent engagements,
        <em>anonymized</em> where required.
      </h2>
    </div>

    <div class="work-grid">
      {
        work.map((entry) => {
          const Thumb = thumbs[entry.id];
          return (
            <article class="work-card">
              <div class="work-thumb">
                {Thumb && <Thumb />}
              </div>
              <div class="work-tag">{entry.data.tag}</div>
              <h3 class="work-title">{entry.data.title}</h3>
              <p class="work-desc">{entry.data.summary}</p>
            </article>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  .work {
    background: var(--paper);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }

  .work-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px;
  }

  .work-card {
    cursor: pointer;
    transition: transform 0.25s;
  }

  .work-card:hover {
    transform: translateY(-4px);
  }

  .work-thumb {
    aspect-ratio: 4/3;
    margin-bottom: 24px;
    background: var(--bg);
    border: 1px solid var(--rule);
    position: relative;
    overflow: hidden;
  }

  .work-tag {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: 10px;
  }

  .work-title {
    font-family: var(--serif);
    font-size: 26px;
    line-height: 1.2;
    margin-bottom: 12px;
    letter-spacing: -0.01em;
    font-weight: 400;
  }

  .work-desc {
    font-size: 14px;
    line-height: 1.6;
    color: var(--ink-soft);
  }

  @media (max-width: 900px) {
    .work-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>
