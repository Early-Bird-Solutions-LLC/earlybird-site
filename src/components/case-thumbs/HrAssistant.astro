---
// Case study thumbnail — HR assistant RAG over SharePoint.
// SharePoint corpus → Azure AI Search vector index → GPT-4o → Blazor + Entra ID.
---

<svg
  class="thumb-svg"
  viewBox="0 0 400 300"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label="Architecture diagram: SharePoint corpus indexed in Azure AI Search, served via GPT-4o through a Blazor app behind Entra ID"
>
  <defs>
    <linearGradient id="g-hr" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%" stop-color="#B8763E" />
      <stop offset="100%" stop-color="#8C5829" />
    </linearGradient>
    <marker id="arrow-hr" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto">
      <path d="M 0 0 L 10 5 L 0 10 z" fill="#0F1A2C" />
    </marker>
  </defs>
  <rect width="400" height="300" fill="#FAF8F2" />

  <!-- SharePoint source -->
  <rect x="40" y="50" width="120" height="60" fill="white" stroke="#D8D2C2" />
  <rect x="40" y="50" width="3" height="60" fill="url(#g-hr)" />
  <text x="52" y="72" font-family="JetBrains Mono" font-size="9" fill="#8A8578">SOURCE</text>
  <text x="52" y="92" font-family="IBM Plex Sans" font-size="12" fill="#0F1A2C">SharePoint · HR docs</text>

  <!-- Arrow → vector store -->
  <path d="M 165 80 L 235 80" stroke="#0F1A2C" stroke-width="1" fill="none" marker-end="url(#arrow-hr)" />

  <!-- AI Search -->
  <rect x="240" y="50" width="120" height="60" fill="white" stroke="#D8D2C2" />
  <rect x="240" y="50" width="3" height="60" fill="url(#g-hr)" />
  <text x="252" y="72" font-family="JetBrains Mono" font-size="9" fill="#8A8578">RETRIEVAL</text>
  <text x="252" y="92" font-family="IBM Plex Sans" font-size="11" fill="#0F1A2C">Azure AI Search</text>

  <!-- GPT-4o reasoning -->
  <rect x="140" y="140" width="120" height="60" fill="white" stroke="#D8D2C2" />
  <rect x="140" y="140" width="3" height="60" fill="url(#g-hr)" />
  <text x="152" y="162" font-family="JetBrains Mono" font-size="9" fill="#8A8578">REASONING</text>
  <text x="152" y="182" font-family="IBM Plex Sans" font-size="12" fill="#0F1A2C">GPT-4o · Foundry</text>
  <path d="M 200 110 L 200 138" stroke="#0F1A2C" stroke-width="1" />

  <!-- Blazor + Entra ID -->
  <rect x="40" y="225" width="320" height="50" fill="white" stroke="#D8D2C2" />
  <rect x="40" y="225" width="4" height="50" fill="url(#g-hr)" />
  <text x="56" y="247" font-family="JetBrains Mono" font-size="9" fill="#8A8578">DELIVERY</text>
  <text x="56" y="265" font-family="IBM Plex Sans" font-size="12" fill="#0F1A2C">.NET 10 Blazor · Entra ID OIDC</text>
  <path d="M 200 202 L 200 223" stroke="#0F1A2C" stroke-width="1" />
</svg>

<style>
  .thumb-svg {
    width: 100%;
    height: 100%;
    display: block;
  }
</style>
