---
// Case study thumbnail — PCI multi-tenant landing zone.
// Illustrates: WAF edge tier → per-tenant isolation cells → compliance services.
---

<svg
  class="thumb-svg"
  viewBox="0 0 400 300"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label="Architecture diagram: Application Gateway WAF over per-tenant cells over compliance tier"
>
  <defs>
    <linearGradient id="g-pci" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%" stop-color="#B8763E" />
      <stop offset="100%" stop-color="#8C5829" />
    </linearGradient>
  </defs>
  <rect width="400" height="300" fill="#FAF8F2" />
  <!-- Edge / WAF tier -->
  <rect x="40" y="40" width="320" height="60" fill="white" stroke="#D8D2C2" />
  <rect x="40" y="40" width="4" height="60" fill="url(#g-pci)" />
  <text x="56" y="62" font-family="JetBrains Mono" font-size="9" fill="#8A8578" letter-spacing="1">EDGE</text>
  <text x="56" y="82" font-family="IBM Plex Sans" font-size="13" fill="#0F1A2C">App Gateway WAF v2</text>
  <!-- Tenant cells -->
  <g>
    <rect x="40" y="120" width="100" height="70" fill="white" stroke="#D8D2C2" />
    <rect x="40" y="120" width="3" height="70" fill="url(#g-pci)" />
    <text x="52" y="142" font-family="JetBrains Mono" font-size="8" fill="#8A8578">TENANT-A</text>
    <circle cx="90" cy="165" r="10" fill="#0F1A2C" />
    <rect x="150" y="120" width="100" height="70" fill="white" stroke="#D8D2C2" />
    <rect x="150" y="120" width="3" height="70" fill="url(#g-pci)" />
    <text x="162" y="142" font-family="JetBrains Mono" font-size="8" fill="#8A8578">TENANT-B</text>
    <circle cx="200" cy="165" r="10" fill="#0F1A2C" />
    <rect x="260" y="120" width="100" height="70" fill="white" stroke="#D8D2C2" />
    <rect x="260" y="120" width="3" height="70" fill="url(#g-pci)" />
    <text x="272" y="142" font-family="JetBrains Mono" font-size="8" fill="#8A8578">TENANT-C</text>
    <circle cx="310" cy="165" r="10" fill="#0F1A2C" />
  </g>
  <!-- Compliance tier -->
  <rect x="40" y="210" width="320" height="50" fill="white" stroke="#D8D2C2" />
  <rect x="40" y="210" width="4" height="50" fill="url(#g-pci)" />
  <text x="56" y="232" font-family="JetBrains Mono" font-size="9" fill="#8A8578" letter-spacing="1">COMPLIANCE</text>
  <text x="56" y="250" font-family="IBM Plex Sans" font-size="12" fill="#0F1A2C">Defender · Sentinel · Deployment Stacks</text>
</svg>

<style>
  .thumb-svg {
    width: 100%;
    height: 100%;
    display: block;
  }
</style>
