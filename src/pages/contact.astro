---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact — Early Bird Solutions"
  description="Get in touch about Azure AI consulting. Direct email and 30-minute intro calls."
>
  <section class="section">
    <div class="container">
      <div class="section-head">
        <div class="section-num">§ Contact</div>
        <h1 class="section-title">
          Let's talk about what you're <em>trying to ship.</em>
        </h1>
      </div>

      <div class="contact-grid">
        <div class="contact-intro">
          <p>
            Best path: a 30-minute intro call. I'll ask what you're trying to
            do and tell you honestly whether I can help.
          </p>
          <p>
            For shorter questions or to send context ahead of a call, email
            works equally well.
          </p>
        </div>

        <div class="contact-channels">
          <a class="channel" href="mailto:jim@earlybirdsolutions.com">
            <div class="channel-label">Email</div>
            <div class="channel-value">jim@earlybirdsolutions.com</div>
            <div class="channel-cta">Send a message →</div>
          </a>

          <a class="channel" href="https://calendly.com/" target="_blank" rel="noopener">
            <div class="channel-label">Calendar</div>
            <div class="channel-value">Schedule a 30-minute call</div>
            <div class="channel-cta">Book on Calendly →</div>
          </a>

          <a class="channel" href="https://www.linkedin.com/" target="_blank" rel="noopener">
            <div class="channel-label">LinkedIn</div>
            <div class="channel-value">Connect or message</div>
            <div class="channel-cta">Open LinkedIn →</div>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 100px;
    align-items: start;
  }

  .contact-intro p {
    font-family: var(--serif);
    font-size: clamp(22px, 2.4vw, 28px);
    line-height: 1.45;
    color: var(--ink);
    margin-bottom: 20px;
    font-style: italic;
  }

  .contact-channels {
    display: flex;
    flex-direction: column;
  }

  .channel {
    display: block;
    padding: 28px 0;
    border-top: 1px solid var(--rule);
    transition: padding-left 0.25s;
  }

  .channel:last-child {
    border-bottom: 1px solid var(--rule);
  }

  .channel:hover {
    padding-left: 12px;
  }

  .channel-label {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: 6px;
  }

  .channel-value {
    font-family: var(--serif);
    font-size: 26px;
    line-height: 1.2;
    margin-bottom: 8px;
    color: var(--ink);
  }

  .channel-cta {
    font-size: 14px;
    color: var(--accent-deep);
  }

  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
  }
</style>
