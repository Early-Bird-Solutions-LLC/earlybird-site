---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { render } from 'astro:content';

const services = (await getCollection('services')).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<BaseLayout
  title="Services — Early Bird Solutions"
  description="Azure AI consulting services: AI Foundry implementation, RAG platforms, .NET integration, and PCI-regulated AI architectures."
>
  <section class="section">
    <div class="container">
      <div class="section-head">
        <div class="section-num">§ Services</div>
        <h1 class="section-title">
          Four practice areas. <em>One philosophy.</em> Ship working systems on
          the Microsoft stack.
        </h1>
      </div>

      <div class="services-list">
        {
          services.map(async (s) => {
            const { Content } = await render(s);
            return (
              <article class="service-detail">
                <div class="service-num">{s.data.number}</div>
                <h2 class="service-title">{s.data.title}</h2>
                <p class="service-summary">{s.data.summary}</p>
                <div class="service-body">
                  <Content />
                </div>
              </article>
            );
          })
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .services-list {
    display: flex;
    flex-direction: column;
  }

  .service-detail {
    padding: 56px 0;
    border-top: 1px solid var(--rule);
  }

  .service-detail:last-child {
    border-bottom: 1px solid var(--rule);
  }

  .service-num {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    color: var(--accent);
    margin-bottom: 14px;
  }

  .service-title {
    font-family: var(--serif);
    font-size: clamp(32px, 4vw, 48px);
    line-height: 1.1;
    margin-bottom: 24px;
    letter-spacing: -0.01em;
    font-weight: 400;
    max-width: 820px;
  }

  .service-summary {
    font-size: 18px;
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 760px;
    margin-bottom: 24px;
  }

  .service-body {
    font-size: 16px;
    line-height: 1.7;
    color: var(--ink-soft);
    max-width: 760px;
  }
</style>
